# Required: search + lyrics (richsync / LRC)
MUSIXMATCH_API_KEY=

# Optional: LALAL.AI vocal separation (PRIMARY for one demo track).
# Leave LALAL_DEMO_TRACK_ID blank to use Demucs for everything (default).
# Set it to the Musixmatch commontrack_id of the track you want LALAL to handle;
# any LALAL failure automatically falls back to Demucs.
LALAL_API_KEY=
LALAL_DEMO_TRACK_ID=

# Optional / unused in current scope
CYANITE_API_KEY=
SONGSTATS_API_KEY=

# Optional: Neon Postgres. If blank, song history uses a local JSON file
# under data/ (persists across dev restarts).
DATABASE_URL=
